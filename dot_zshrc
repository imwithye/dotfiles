# oh-my-zsh
export ZSH=$HOME/.oh-my-zsh
ZSH_THEME="refined"
plugins=(zsh-syntax-highlighting docker z)
source $ZSH/oh-my-zsh.sh

export LC_CTYPE=en_US.UTF-8
export LANG=en_US.UTF-8

# Homebrew
test -d /opt/homebrew && eval "$(/opt/homebrew/bin/brew shellenv)"
# Linuxbrew
test -d /home/linuxbrew/.linuxbrew && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# Rustup
test -d /opt/homebrew/opt/rustup/bin && export PATH="/opt/homebrew/opt/rustup/bin:$PATH"

# Ruby
test -d /opt/homebrew/opt/ruby/bin && export PATH="/opt/homebrew/opt/ruby/bin:$PATH"

# Update Path
export PATH=$HOME/bin:$HOME/.bin:$HOME/.local/bin:$PATH

# Update KUBECONFIG
export KUBECONFIG="$HOME/.kube/config"
for f in "$HOME"/.kube/kubeconfig.d/*.yaml(N); do
  KUBECONFIG="$KUBECONFIG:$f"
done

# K9s
export K9S_CONFIG_DIR="$HOME/.config/k9s"

# PNPM
export PNPM_HOME=$HOME/.pnpm
export PATH=$PATH:$PNPM_HOME

# Add iCloud to Home
test -d "$HOME/Library/Mobile Documents/com~apple~CloudDocs/" && ! test -d "$HOME/iCloud" && ln -s "$HOME/Library/Mobile Documents/com~apple~CloudDocs/" "$HOME/iCloud"

# alacritty will cause issue on SSH
if [[ "$TERM" == "alacritty" || "$TERM" == "xterm-ghostty" ]]; then
  alias ssh='TERM=xterm-256color ssh'
  alias orb='TERM=xterm-256color orb'
fi

checkinstall() {
  command -v $@ >/dev/null
}

# 1Password Environment Variables
if checkinstall op; then
  loadenv() {
    export OPENAI_API_KEY=$(op item get "OpenAI" --vault Private --fields PAT --reveal)
    export GITHUB_TOKEN=$(op item get "GitHub" --vault Private --fields PAT --reveal)
  }
  alias loadenv='loadenv'
fi

if checkinstall nvim; then
  alias vim=nvim
  export EDITOR=nvim
fi

if checkinstall neovide; then
  alias neovide='neovide --fork'
fi

if checkinstall go; then
  export GOPATH=$HOME/.local/go
  export GO111MODULE=on
  export PATH=$GOPATH/bin:$PATH
  mkdir -p $GOPATH
fi

if checkinstall conda; then
  eval "$(conda "shell.$(basename "${SHELL}")" hook)"
  if conda env list | grep -q "^dev "; then
    conda activate dev
  fi
fi

if checkinstall kubectl; then
  kubectl config use-context orbstack >/dev/null 2>&1 || true
  alias k=kubectl
  alias kshell='kubectl run kshell --image=nicolaka/netshoot --rm -it'
  export PATH=$HOME/.krew/bin:$PATH

  # kube-ps1: show current context in RPROMPT (only if installed)
  for _kps1 in \
    /home/linuxbrew/.linuxbrew/opt/kube-ps1/share/kube-ps1.sh \
    /opt/homebrew/opt/kube-ps1/share/kube-ps1.sh \
    /usr/share/kube-ps1/kube-ps1.sh; do
    if [ -r "$_kps1" ]; then
      source "$_kps1"
      KUBE_PS1_SYMBOL_ENABLE=false
      RPROMPT='%F{#7f849c}${SSH_TTY:+%n@%m }%f$(kube_ps1)'
      break
    fi
  done
  unset _kps1
fi

if checkinstall kubectx; then
  alias kx=kubectx
fi

if checkinstall fzf; then
  source <(fzf --zsh)
  alias fzf='fzf --reverse --preview "cat {}"'
  if checkinstall bat; then
    alias fzf='fzf --reverse --preview "bat --style=numbers,changes --color=always {}"'
  fi
fi

if checkinstall lazydocker; then
  alias lzd=lazydocker
fi

# User configuration
if [ -f $HOME/.zshrc.local ]; then
  source $HOME/.zshrc.local
fi
